# {{ ansible_managed }}
# Prometheus alert rules - generated by Ansible

groups:
  - name: monitoring_alerts
    rules:
{% for rule in prometheus_alert_rules %}
      - alert: {{ rule.alert }}
        expr: {{ rule.expr }}
        for: {{ rule.for }}
        labels:
          severity: {{ rule.severity }}
        annotations:
          summary: "{{ rule.summary }}"
          description: "{{ rule.description }}"

{% endfor %}
